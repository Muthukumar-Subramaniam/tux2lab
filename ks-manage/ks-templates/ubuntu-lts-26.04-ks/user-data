#cloud-config
##After installation autoinstall steps are stored in the system under /var/log/installer/autoinstall-user-data
autoinstall:
  version: 1

  apt:
    disable_suites: [security, updates]
    conf: |
      APT::Periodic::Enable "0";
      Unattended-Upgrade::Automatic-Reboot "false";

  early-commands:
    - echo "ttyS0" >> /etc/securetty
    - systemctl start serial-getty@ttyS0.service
    - systemctl mask --now systemd-networkd-wait-online.service

  source:
   id: ubuntu-server-minimal

  identity:
    hostname: get_hostname.get_ipv4_domain
    password: "get_shadow_password_super_mgmt_user"
    username: get_mgmt_super_user

  user-data:
    timezone: UTC
    chpasswd:
      expire: false
      list:
        - root:get_shadow_password_super_mgmt_user
    runcmd:
      - curl -sf http://get_lab_infra_server_hostname/ksmanager-hub/kickstarts/get_hostname.get_ipv4_domain/post-install.sh -o /root/tux2lab-post-install.sh
      - chmod 700 /root/tux2lab-post-install.sh
      - /root/tux2lab-post-install.sh

  keyboard:
    layout: us
    toggle: null
    variant: ''

  locale: en_US.UTF-8

  ssh:
    allow-pw: true
    authorized-keys: []
    install-server: true

  storage:
    config:
# Configure Disk
      - ptable: gpt
        path: /dev/get_disk_type_for_the_vm
        wipe: superblock-recursive
        preserve: false
        name: ''
        grub_device: false
        id: disk-get_disk_type_for_the_vm
        type: disk
# EFI partition
      - device: disk-get_disk_type_for_the_vm
        size: 134217728
        wipe: superblock
        flag: boot
        number: 1
        preserve: false
        grub_device: true
        id: partition-0
        type: partition
      - fstype: fat32
        volume: partition-0
        preserve: false
        id: format-0
        type: format
      - path: /boot/efi
        device: format-0
        id: mount-0
        type: mount
# /boot partition
      - device: disk-get_disk_type_for_the_vm
        size: 1073741824
        wipe: superblock
        number: 2
        preserve: false
        id: partition-1
        type: partition
      - fstype: xfs
        volume: partition-1
        preserve: false
        id: format-1
        type: format
      - path: /boot
        device: format-1
        id: mount-1
        type: mount
# / (root) partition
      - device: disk-get_disk_type_for_the_vm
        size: -1
        wipe: superblock
        number: 3
        preserve: false
        id: partition-2
        type: partition
      - fstype: xfs
        volume: partition-2
        preserve: false
        id: format-2
        type: format
      - path: /
        device: format-2
        id: mount-2
        type: mount

  late-commands:
    - mkdir -p /target/etc/systemd/network
    - V_count=0;for v_interface in $(ls /sys/class/net | grep -v lo);do /target/usr/bin/echo -e "[Match]\nMACAddress=$(ip link | grep $v_interface -A 1 | grep link/ether | cut -d " " -f 6)\n\n[Link]\nName=eth$V_count" >/target/etc/systemd/network/7$V_count-eth$V_count.link;V_count=$((V_count+1));done
    - mkdir -p /target/etc/netplan/old
    - if ls /target/etc/netplan/*.yaml;then mv /target/etc/netplan/*.yaml /target/etc/netplan/old;fi
    - curl -fsSL http://get_lab_infra_server_hostname/ksmanager-hub/kickstarts/get_hostname.get_ipv4_domain/ubuntu-lts-get_version-ks/eth0.yaml -o /target/etc/netplan/eth0.yaml
    - curl -fsSL http://get_lab_infra_server_hostname/ksmanager-hub/kickstarts/get_hostname.get_ipv4_domain/ubuntu-lts-get_version-ks/auto-create-int.yaml -o /target/etc/netplan/auto-create-int.yaml
    - V_count=1;for v_interface in $(ls /target/etc/systemd/network/ | grep -v eth0);do sed "s/eth-get_mgmt_super_user/eth$V_count/g" /target/etc/netplan/auto-create-int.yaml >/target/etc/netplan/eth$V_count.yaml;V_count=$((V_count+1));done
    - chmod 600 /target/etc/netplan/eth*.yaml
    - rm -rf /target/etc/netplan/auto-create-int.yaml
    - /target/usr/bin/sed -i 's/^GRUB_CMDLINE_LINUX_DEFAULT=.*/GRUB_CMDLINE_LINUX_DEFAULT="console=ttyS0,115200n8 nomodeset"/' /target/etc/default/grub
    - curtin in-target --target=/target -- update-grub
    - ln -sf /dev/null /target/etc/systemd/system/systemd-networkd-wait-online.service
    - date '+%Y-%m-%d %H:%M:%S %Z' > /target/etc/bigbang
