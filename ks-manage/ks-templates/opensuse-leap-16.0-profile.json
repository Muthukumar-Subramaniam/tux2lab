{
  "product": {
    "id": "openSUSE_Leap"
  },
  "localization": {
    "keyboard": "us",
    "timezone": "UTC",
    "language": "en_US.UTF-8"
  },
  "storage": {
    "boot": {
      "configure": true
    },
    "drives": [
      {
        "search": "/dev/get_disk_type_for_the_vm",
        "ptableType": "gpt",
        "partitions": [
          {
            "id": "esp",
            "size": "512 MiB",
            "filesystem": {
              "type": "vfat",
              "path": "/boot/efi"
            }
          },
          {
            "id": "linux",
            "size": { "min": "10 GiB" },
            "filesystem": {
              "type": "xfs",
              "path": "/"
            }
          }
        ]
      }
    ]
  },
  "network": {
    "connections": [
      {
        "id": "static-net",
        "interface": "eth0",
        "method4": "manual",
        "method6": "manual",
        "addresses": [
          "get_ipv4_address/get_ipv4_prefix",
          "get_ipv6_address/get_ipv6_prefix"
        ],
        "gateway4": "get_ipv4_gateway",
        "gateway6": "get_ipv6_gateway",
        "nameservers": [
          "get_ipv4_nameserver",
          "get_ipv6_nameserver"
        ],
        "autoconnect": true
      }
    ]
  },
  "hostname": {
    "static": "get_hostname.get_ipv4_domain"
  },
  "software": {
    "patterns": [
      "apparmor",
      "base",
      "enhanced_base",
      "minimal_base",
      "sw_management"
    ],
    "packages": [
      "autofs",
      "nfs-client"
    ]
  },
  "user": {
    "fullName": "get_mgmt_super_user",
    "userName": "get_mgmt_super_user",
    "password": "get_shadow_password_super_mgmt_user",
    "hashedPassword": true
  },
  "root": {
    "password": "get_shadow_password_super_mgmt_user",
    "hashedPassword": true
  },
  "bootloader": {
    "stopOnBootMenu": false,
    "extraKernelParams": "console=ttyS0,115200n8 mitigations=auto quiet security=apparmor"
  },
  "scripts": {
    "post": [
      {
        "name": "tux2lab-post-install.sh",
        "content": "#!/bin/bash\ncurl -sf http://get_lab_infra_server_hostname/ksmanager-hub/kickstarts/get_hostname.get_ipv4_domain/post-install.sh -o /root/tux2lab-post-install.sh\nchmod 700 /root/tux2lab-post-install.sh\n/root/tux2lab-post-install.sh"
      }
    ]
  }
}
